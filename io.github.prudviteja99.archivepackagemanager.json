{
    "app-id": "io.github.prudviteja99.archivepackagemanager",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.7",
    "sdk": "org.kde.Sdk",
    "base": "com.riverbankcomputing.PyQt.BaseApp",
    "base-version": "6.7",
    "command": "archive-package-manager",
    "build-options": {
        "append-path": "/usr/lib/sdk/python312/bin",
        "env": {}
    },
    "finish-args": [
        "--share=ipc",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--filesystem=home",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.Flatpak"
    ],
    "modules": [
        {
            "name": "archive-package-manager",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 src/main.py ${FLATPAK_DEST}/bin/main.py",
                "install -Dm755 src/database.py ${FLATPAK_DEST}/bin/database.py",
                "install -Dm755 src/workers.py ${FLATPAK_DEST}/bin/workers.py",
                "install -Dm644 src/ArchivePackageManager.ui ${FLATPAK_DEST}/bin/ArchivePackageManager.ui",
                "install -Dm755 bin/archive-package-manager ${FLATPAK_DEST}/bin/archive-package-manager",
                "install -Dm644 assets/icons/app_icon_resized.png ${FLATPAK_DEST}/share/icons/hicolor/256x256/apps/io.github.prudviteja99.archivepackagemanager.png",
                "install -Dm644 assets/icons/appimage_icon.png ${FLATPAK_DEST}/bin/assets/icons/appimage_icon.png",
                "install -Dm644 assets/icons/app_icon.png ${FLATPAK_DEST}/bin/assets/icons/app_icon.png",
                "install -Dm644 assets/icons/appimage_icon_resized.png ${FLATPAK_DEST}/bin/assets/icons/appimage_icon_resized.png",
                "install -Dm644 assets/icons/targz_icon_resized.png ${FLATPAK_DEST}/bin/assets/icons/targz_icon_resized.png",
                "install -Dm644 assets/icons/targz_icon.png ${FLATPAK_DEST}/bin/assets/icons/targz_icon.png",
                "install -Dm644 data/io.github.prudviteja99.archivepackagemanager.desktop ${FLATPAK_DEST}/share/applications/io.github.prudviteja99.archivepackagemanager.desktop",
                "install -Dm644 data/io.github.prudviteja99.archivepackagemanager.metainfo.xml ${FLATPAK_DEST}/share/metainfo/io.github.prudviteja99.archivepackagemanager.metainfo.xml"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}